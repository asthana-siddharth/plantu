PORT=4000

# Single MySQL instance for POC
DB_PRIMARY_HOST=127.0.0.1
DB_PRIMARY_PORT=3306
DB_PRIMARY_USER=root
DB_PRIMARY_PASSWORD=
DB_PRIMARY_NAME=plantu_db
DB_PRIMARY_POOL_SIZE=10

# Optional backward-compatible read envs.
# If omitted, backend falls back to DB_PRIMARY_* values.
# DB_SECONDARY_HOST=127.0.0.1
# DB_SECONDARY_PORT=3306
# DB_SECONDARY_USER=root
# DB_SECONDARY_PASSWORD=
# DB_SECONDARY_NAME=plantu_db
# DB_SECONDARY_POOL_SIZE=10
